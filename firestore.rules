
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // Super admin bypass for your specific email
    function isSuperAdmin() { 
      return isSignedIn() && request.auth.token.email == 'aicystevens0@gmail.com'; 
    }
    
    function isAdmin() { 
      return isSuperAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid))); 
    }

    match /users/{userId}/profile/details {
      allow get: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId);
    }

    match /users/{userId}/applications/{applicationId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) || isAdmin();
    }

    match /global_applications/{applicationId} {
      // Allow list for uniqueness checks by transaction code
      allow get, list: if isSignedIn() || isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && request.resource.data.applicantId == request.auth.uid);
    }

    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow create: if isOwner(adminId) || isSuperAdmin();
    }
  }
}
