
{
  "entities": {
    "Applicant": {
      "title": "Applicant",
      "type": "object",
      "description": "Stores personal information and profile details of the job seeker.",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "email": { "type": "string" },
        "nationalIdNumber": { "type": "string" },
        "county": { "type": "string" },
        "ward": { "type": "string" },
        "highestEducationQualification": { "type": "string" },
        "registrationDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "fullName", "phoneNumber", "email", "nationalIdNumber", "registrationDate"]
    },
    "Application": {
      "title": "Application",
      "type": "object",
      "description": "Represents a job application and its multi-stage approval lifecycle.",
      "properties": {
        "id": { "type": "string" },
        "applicantId": { "type": "string" },
        "jobPostingId": { "type": "string" },
        "submissionDate": { "type": "string", "format": "date-time" },
        "status": { 
          "type": "string", 
          "enum": ["payment_pending", "payment_approved", "docs_pending", "docs_uploaded", "ecitizen_paid", "docs_approved"],
          "description": "payment_pending: User submitted Ksh 950. payment_approved: Admin verified payment. docs_uploaded: User uploaded CV/Certs. ecitizen_paid: User paid Ksh 1027. docs_approved: Admin final approval."
        },
        "mpesaCode950": { "type": "string" },
        "mpesaCode1027": { "type": "string" },
        "educationDetails": { "type": "string" },
        "documentsUploadedAt": { "type": "string", "format": "date-time" },
        "finalApprovalDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "applicantId", "jobPostingId", "submissionDate", "status"]
    }
  },
  "auth": {
    "providers": ["anonymous", "password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}/applicant_profile",
        "definition": {
          "entityName": "Applicant",
          "description": "User's core profile data."
        }
      },
      {
        "path": "/users/{userId}/applications/{applicationId}",
        "definition": {
          "entityName": "Application",
          "description": "User's job application tracking doc."
        }
      },
      {
        "path": "/admins/{adminId}",
        "definition": {
          "entityName": "Admin",
          "description": "Database Access Control list for administrators."
        }
      },
      {
        "path": "/global_applications/{applicationId}",
        "definition": {
          "entityName": "Application",
          "description": "Denormalized collection for administrative overview."
        }
      }
    ]
  }
}
